{
  "name": "gooseherd",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://goose-herd.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/Chocksy/gooseherd.git"
  },
  "description": "Self-hosted AI coding agent orchestrator — herds Goose agents via Slack and opens PRs",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc --noEmit",
    "test": "node --test --import tsx tests/*.test.ts",
    "local:trigger": "tsx src/local-trigger.ts",
    "inspect": "tsx scripts/inspect-run.ts",
    "validate": "tsx scripts/validate-env.ts",
    "setup": "tsx scripts/setup.ts"
  },
  "dependencies": {
    "@browserbasehq/stagehand": "^3.1.0",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.0",
    "@slack/bolt": "^4.5.0",
    "deepmerge": "^4.3.1",
    "dockerode": "^4.0.9",
    "dotenv": "^16.5.0",
    "p-queue": "^8.1.1",
    "playwright": "^1.58.2",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@clack/prompts": "^1.0.1",
    "@types/dockerode": "^4.0.1",
    "@types/node": "^22.13.9",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

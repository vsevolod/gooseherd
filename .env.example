# ═══════════════════════════════════════════════════════════════
# Gooseherd — Configuration
# Only commonly-changed vars shown. All vars have sensible defaults
# in config.ts; override only what you need.
# ═══════════════════════════════════════════════════════════════

# ── Branding ──
APP_NAME=Gooseherd

# ── Slack (required) ──
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...
SLACK_COMMAND_NAME=gooseherd
# SLACK_ALLOWED_CHANNELS=C123,C456

# ── GitHub (required — use EITHER PAT or GitHub App) ──
GITHUB_TOKEN=ghp_...
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_INSTALLATION_ID=
GITHUB_DEFAULT_OWNER=hubstaff

# ── Repo allowlist (comma-separated) ──
REPO_ALLOWLIST=

# ── API Keys ──
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ── Agent ──
AGENT_COMMAND_TEMPLATE=bash scripts/dummy-agent.sh {{repo_dir}} {{prompt_file}} {{run_id}}
# pi-agent example:
# AGENT_COMMAND_TEMPLATE=cd {{repo_dir}} && pi -p @{{prompt_file}} --model openrouter/openai/gpt-4.1-mini --no-session --mode json --tools read,write,edit,bash,grep,find,ls {{pi_extensions}} {{mcp_flags}}
AGENT_TIMEOUT_SECONDS=600

# Validation + lint (leave empty to skip)
VALIDATION_COMMAND=
LINT_FIX_COMMAND=
# LOCAL_TEST_COMMAND=

# ── Runtime ──
DRY_RUN=true
RUNNER_CONCURRENCY=1
# WORK_ROOT=.work
# DATA_DIR=data

# ── Dashboard ──
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8787
# DASHBOARD_PUBLIC_URL=https://gooseherd.example.com
# DASHBOARD_TOKEN=

# ── LLM Models ──
# Shared default for all LLM features (plan_task, scope_judge, browser_verify, smart_triage).
# Individual overrides (PLAN_TASK_MODEL, SCOPE_JUDGE_MODEL, etc.) take precedence.
DEFAULT_LLM_MODEL=anthropic/claude-haiku-4-5
# ORCHESTRATOR_MODEL=openai/gpt-4.1-mini
# ORCHESTRATOR_TIMEOUT_MS=180000
# ORCHESTRATOR_WALL_CLOCK_TIMEOUT_MS=480000

# ── Pipeline ──
PIPELINE_FILE=pipelines/pipeline.yml

# ── Browser Verify (optional) ──
# BROWSER_VERIFY_ENABLED=false
# REVIEW_APP_URL_PATTERN=https://{{prNumber}}.stg.epicpxls.com

# ── CI Feedback Loop (optional) ──
# CI_WAIT_ENABLED=false

# ── Observer / Trigger System (optional) ──
# OBSERVER_ENABLED=false
# OBSERVER_ALERT_CHANNEL_ID=
# OBSERVER_RULES_FILE=observer-rules/default.yml
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG_SLUG=

# ── Sandbox (optional, Docker-out-of-Docker) ──
# SANDBOX_ENABLED=false
# SANDBOX_HOST_WORK_PATH=

# ── CEMS Memory (optional) ──
# CEMS_ENABLED=false
# CEMS_API_URL=http://localhost:8100
# CEMS_API_KEY=

# ── Pi-Agent / MCP Extensions ──
# PI_AGENT_EXTENSIONS=/app/extensions/gooseherd-cems.ts
# MCP_EXTENSIONS=

# ── Team → Channel Mapping (JSON) ──
# TEAM_CHANNEL_MAP={"platform":["C123","C456"]}

# ═══════════════════════════════════════════════════════════════
# Advanced tuning (rarely changed — defaults are fine)
# ═══════════════════════════════════════════════════════════════
# MAX_VALIDATION_ROUNDS=2
# SLACK_PROGRESS_HEARTBEAT_SECONDS=20
# MAX_TASK_CHARS=4000
# WORKSPACE_CLEANUP_ENABLED=true
# WORKSPACE_MAX_AGE_HOURS=24
# SCOPE_JUDGE_ENABLED=false
# SCOPE_JUDGE_MIN_PASS_SCORE=60
# OBSERVER_SMART_TRIAGE_ENABLED=false
# SUPERVISOR_ENABLED=true
# SUPERVISOR_MAX_AUTO_RETRIES=1
# SUPERVISOR_RUN_TIMEOUT_SECONDS=7200
# OPENROUTER_PROVIDER_PREFERENCES={"ignore":["DeepInfra"]}

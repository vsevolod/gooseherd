# ═══════════════════════════════════════════════════════════════
# Gooseherd — Configuration
# Only commonly-changed vars shown. All vars have sensible defaults
# in config.ts; override only what you need.
# ═══════════════════════════════════════════════════════════════

# ── Database ──
# DATABASE_URL=postgres://gooseherd:gooseherd@localhost:5432/gooseherd
# ENCRYPTION_KEY=  # 64-char hex (auto-generated by setup wizard if unset)

# ── Branding ──
APP_NAME=Gooseherd

# ── Slack (optional — omit for dashboard-only mode) ──
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
SLACK_SIGNING_SECRET=...
SLACK_COMMAND_NAME=gooseherd
# SLACK_ALLOWED_CHANNELS=C123,C456

# ── GitHub (required — use EITHER PAT or GitHub App) ──
GITHUB_TOKEN=ghp_...
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=
# GITHUB_APP_INSTALLATION_ID=
GITHUB_DEFAULT_OWNER=

# ── Repo allowlist (comma-separated) ──
REPO_ALLOWLIST=

# ── API Keys ──
OPENROUTER_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# CODEX_API_KEY=          # OpenAI Codex CLI
# CURSOR_API_KEY=         # Cursor Agent CLI

# ── Agent ──
# Default uses dummy-agent.sh (a safe no-op test stub — creates a file and screenshot, nothing more).
# Replace with your real agent for actual coding runs.
# Any CLI that reads a prompt, edits code, and exits works. The sandbox image includes all agents below.
AGENT_COMMAND_TEMPLATE=bash scripts/dummy-agent.sh {{repo_dir}} {{prompt_file}} {{run_id}}
#
# pi-agent (needs OPENROUTER_API_KEY):
# AGENT_COMMAND_TEMPLATE=cd {{repo_dir}} && pi -p @{{prompt_file}} --model openrouter/openai/gpt-4.1-mini --no-session --mode json --tools read,write,edit,bash,grep,find,ls {{pi_extensions}} {{mcp_flags}}
#
# Goose (needs OPENROUTER_API_KEY or provider-specific key):
# AGENT_COMMAND_TEMPLATE=cd {{repo_dir}} && goose run --no-session -i {{prompt_file}}
#
# OpenAI Codex CLI (needs CODEX_API_KEY):
# AGENT_COMMAND_TEMPLATE=cd {{repo_dir}} && codex exec --full-auto "$(cat {{prompt_file}})"
#
# Claude Code CLI (needs ANTHROPIC_API_KEY):
# AGENT_COMMAND_TEMPLATE=cd {{repo_dir}} && claude -p "$(cat {{prompt_file}})" --allowedTools "Read,Edit,Write,Bash,Grep,Glob"
#
# Cursor Agent CLI (needs CURSOR_API_KEY):
# AGENT_COMMAND_TEMPLATE=cd {{repo_dir}} && cursor-agent "$(cat {{prompt_file}})" --no-interactive
#
# AGENT_FOLLOW_UP_TEMPLATE=
AGENT_TIMEOUT_SECONDS=600

# Validation + lint (leave empty to skip)
VALIDATION_COMMAND=
LINT_FIX_COMMAND=
# LOCAL_TEST_COMMAND=

# ── Git Identity ──
# BRANCH_PREFIX=gooseherd
# DEFAULT_BASE_BRANCH=main
# GIT_AUTHOR_NAME=Gooseherd Bot
# GIT_AUTHOR_EMAIL=gooseherd-bot@local

# ── Runtime ──
DRY_RUN=true
RUNNER_CONCURRENCY=1
# WORK_ROOT=.work
# DATA_DIR=data

# ── Dashboard ──
DASHBOARD_ENABLED=true
DASHBOARD_PORT=8787
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PUBLIC_URL=https://gooseherd.example.com
# DASHBOARD_TOKEN=

# ── LLM Models ──
# Shared default for all LLM features (plan_task, scope_judge, browser_verify, smart_triage).
# Individual overrides (PLAN_TASK_MODEL, SCOPE_JUDGE_MODEL, etc.) take precedence.
DEFAULT_LLM_MODEL=anthropic/claude-sonnet-4-6
# PLAN_TASK_MODEL=
# SCOPE_JUDGE_MODEL=
# ORCHESTRATOR_MODEL=openai/gpt-4.1-mini
# ORCHESTRATOR_ENABLED=false
# ORCHESTRATOR_TIMEOUT_MS=180000
# ORCHESTRATOR_WALL_CLOCK_TIMEOUT_MS=480000

# ── Pipeline ──
PIPELINE_FILE=pipelines/pipeline.yml

# ── Browser Verify (optional) ──
# BROWSER_VERIFY_ENABLED=false
# SCREENSHOT_ENABLED=false
# REVIEW_APP_URL_PATTERN=https://{{prNumber}}.preview.example.com
# BROWSER_VERIFY_MODEL=openai/gpt-4.1-mini
# BROWSER_VERIFY_EXECUTION_MODEL=
# BROWSER_VERIFY_MAX_STEPS=15
# BROWSER_VERIFY_EXEC_TIMEOUT_MS=300000
# BROWSER_VERIFY_TEST_EMAIL=qa@example.com
# BROWSER_VERIFY_TEST_PASSWORD=
# BROWSER_VERIFY_EMAIL_DOMAINS=gmail.com,outlook.com

# ── CI Feedback Loop (optional) ──
# CI_WAIT_ENABLED=false
# CI_POLL_INTERVAL_SECONDS=30
# CI_PATIENCE_TIMEOUT_SECONDS=300
# CI_MAX_WAIT_SECONDS=1800
# CI_CHECK_FILTER=
# CI_MAX_FIX_ROUNDS=2

# ── Observer / Trigger System (optional) ──
# OBSERVER_ENABLED=false
# OBSERVER_ALERT_CHANNEL_ID=
# OBSERVER_RULES_FILE=observer-rules/default.yml
# OBSERVER_WEBHOOK_PORT=9090
# OBSERVER_WEBHOOK_SECRETS=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG_SLUG=
# OBSERVER_GITHUB_WATCHED_REPOS=owner/repo
# OBSERVER_SLACK_WATCHED_CHANNELS=
# OBSERVER_SLACK_BOT_ALLOWLIST=
# OBSERVER_REPO_MAP=sentry-project:owner/repo
# OBSERVER_GITHUB_WEBHOOK_SECRET=
# OBSERVER_SENTRY_WEBHOOK_SECRET=

# ── Sandbox (optional, Docker-out-of-Docker) ──
# SANDBOX_ENABLED=false
# SANDBOX_IMAGE=gooseherd/sandbox:default
# SANDBOX_HOST_WORK_PATH=
# SANDBOX_CPUS=2
# SANDBOX_MEMORY_MB=4096

# ── CEMS Memory (optional) ──
# CEMS_ENABLED=false
# CEMS_API_URL=http://localhost:8100
# CEMS_API_KEY=
# CEMS_TEAM_ID=

# ── Pi-Agent / MCP Extensions ──
# PI_AGENT_EXTENSIONS=/app/extensions/gooseherd-cems.ts
# MCP_EXTENSIONS=

# ── Team → Channel Mapping (JSON) ──
# TEAM_CHANNEL_MAP={"platform":["C123","C456"]}

# ═══════════════════════════════════════════════════════════════
# Advanced tuning (rarely changed — defaults are fine)
# ═══════════════════════════════════════════════════════════════
# MAX_VALIDATION_ROUNDS=2
# SLACK_PROGRESS_HEARTBEAT_SECONDS=20
# MAX_TASK_CHARS=4000
# WORKSPACE_CLEANUP_ENABLED=true
# WORKSPACE_MAX_AGE_HOURS=24
# WORKSPACE_CLEANUP_INTERVAL_MINUTES=30
# SCOPE_JUDGE_ENABLED=false
# SCOPE_JUDGE_MIN_PASS_SCORE=60
# OBSERVER_SMART_TRIAGE_ENABLED=false
# OBSERVER_SMART_TRIAGE_MODEL=
# OBSERVER_SMART_TRIAGE_TIMEOUT_MS=10000
# SUPERVISOR_ENABLED=true
# SUPERVISOR_MAX_AUTO_RETRIES=1
# SUPERVISOR_RUN_TIMEOUT_SECONDS=7200
# SUPERVISOR_NODE_STALE_SECONDS=1800
# SUPERVISOR_WATCHDOG_INTERVAL_SECONDS=30
# SUPERVISOR_RETRY_COOLDOWN_SECONDS=60
# SUPERVISOR_MAX_RETRIES_PER_DAY=20
# AUTONOMOUS_SCHEDULER_ENABLED=false
# AUTONOMOUS_SCHEDULER_MAX_DEFERRED=100
# AUTONOMOUS_SCHEDULER_INTERVAL_MS=300000
# OPENROUTER_PROVIDER_PREFERENCES={"ignore":["DeepInfra"]}
